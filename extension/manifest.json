{
  "manifest_version": 3,
  "name": "SecureSurf",
  "version": "1.0.0",
  "description": "AI-powered phishing detection and protection",
  "permissions": ["storage", "activeTab", "scripting", "webNavigation"],
  "host_permissions": ["<all_urls>", "http://localhost:5000/*"],
  "background": {
    "service_worker": "background/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "content/modules/EducationalOverlay.js",
        "content/contentScript.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/modules/*"],
      "matches": ["<all_urls>"]
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "SecureSurf",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
